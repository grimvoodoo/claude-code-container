# Database password (used by both postgres container and the app)
DB_PASSWORD=changeme

# Full connection string for the backend when running locally (cargo run).
# When deployed via docker-compose.deploy.yml the hostname is overridden to 'db'.
# Must match DB_PASSWORD above.
DATABASE_URL=postgres://claude:changeme@localhost:5432/claude_container

# Claude auth — pick one:
#   Option A (subscription): leave ANTHROPIC_API_KEY unset; docker-compose.deploy.yml
#   mounts ~/.claude/.credentials.json automatically. Run 'claude login' on your host first.
#   Option B (API key): set the variable below.
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for cloning private repos (optional)
# GITHUB_TOKEN=ghp_...

# Server config (backend)
PORT=3000
WORKSPACE_DIR=/workspace
STATIC_DIR=./crates/frontend/dist
