# Database (required)
DATABASE_URL=postgres://claude:secret@localhost:5432/claude_container

# Subscription auth (recommended): leave ANTHROPIC_API_KEY unset.
# docker-compose.yml mounts ~/.claude from your host automatically.
# Just make sure you've run 'claude login' on your host first.

# API key auth (alternative): uncomment and fill in
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for cloning private repos (optional)
GITHUB_TOKEN=ghp_...

# Server config
PORT=3000
WORKSPACE_DIR=/workspace
STATIC_DIR=./crates/frontend/dist
